{
  "name": "fec-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for FEC campaign finance research and transparency",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "fec-mcp-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build && npm run typecheck"
  },
  "keywords": [
    "mcp",
    "fec",
    "campaign-finance",
    "transparency",
    "model-context-protocol",
    "federal-election-commission",
    "openai",
    "claude",
    "ai-tools"
  ],
  "author": "Shawn Patterson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sh-patterson/fec-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/sh-patterson/fec-mcp-server/issues"
  },
  "homepage": "https://github.com/sh-patterson/fec-mcp-server#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
